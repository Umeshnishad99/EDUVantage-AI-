# Server Config
PORT=5000

# Database (PostgreSQL - Individual)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=student_performance_ai
DB_PASSWORD=yourpassword
DB_PORT=5432

# Neon/Production Connection String (Overrides individual DB_* variables)
# DATABASE_URL=postgresql://user:pass@ep-name.region.aws.neon.tech/neondb?sslmode=require

# Authentication
JWT_SECRET=your_super_secret_key_change_this

# ML Model API (FastAPI)
ML_API_URL=http://localhost:8000

# Gmail SMTP Configuration (Optional)
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_app_password
APP_URL=http://localhost:5173

# Gemini AI (Chatbot)
GEMINI_API_KEY=your_gemini_api_key
